{
  "name": "mentino",
  "version": "1.0.0",
  "type": "module",
  "description": "Mentorship marketplace connecting students with working professionals",
  "scripts": {
    "dev": "bun run --hot src/index.tsx",
    "start": "bun run src/index.tsx",
    "build": "bun build api/index.ts --outdir=api --outfile=api/index.mjs --target=node --minify",
    "css:build": "bunx tailwindcss -i ./src/styles/input.css -o ./public/styles/output.css",
    "css:watch": "bunx tailwindcss -i ./src/styles/input.css -o ./public/styles/output.css --watch"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "@supabase/supabase-js": "^2.49.0",
    "bcryptjs": "^3.0.3",
    "hono": "^4.7.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "bun-types": "^1.2.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.7.0"
  }
}
